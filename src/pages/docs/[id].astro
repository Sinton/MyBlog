---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "astro-newspaper-theme/layouts/BaseLayout.astro";
import ArticleReadMore from "astro-newspaper-theme/components/ArticleReadMore.astro";
import ArticleToc from "astro-newspaper-theme/components/ArticleToc.astro";
import Masthead from "astro-newspaper-theme/components/Masthead.astro";
import StampTag from "astro-newspaper-theme/components/StampTag.astro";
import { formatDate } from "astro-newspaper-theme/lib/format";
import { themeConfig } from "@/theme.config";
import "../../styles/example.css";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter((heading) => heading.depth === 2);
---

<BaseLayout title={entry.data.title} description={entry.data.description} config={themeConfig}>
  <Masthead config={themeConfig} date={entry.data.updated} />
  <main class="detail-page">
    <article class="column-page">
      <header class="column-page__header column-page__header--article">
        <StampTag label={entry.data.category} tone="red" />
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        {
          entry.data.updated && (
            <time datetime={entry.data.updated.toISOString()}>
              更新于 {formatDate(entry.data.updated, themeConfig)}
            </time>
          )
        }
      </header>
      <ArticleToc headings={tocHeadings} numberStyle={themeConfig.tocNumberStyle} />
      <div class="prose">
        <Content />
      </div>
      <ArticleReadMore indexHref="/docs/" indexLabel="返回说明书" />
    </article>
  </main>
</BaseLayout>
