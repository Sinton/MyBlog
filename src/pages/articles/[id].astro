---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "astro-newspaper-theme/layouts/BaseLayout.astro";
import ArticleReadMore from "astro-newspaper-theme/components/ArticleReadMore.astro";
import ArticleToc from "astro-newspaper-theme/components/ArticleToc.astro";
import Masthead from "astro-newspaper-theme/components/Masthead.astro";
import StampTag from "astro-newspaper-theme/components/StampTag.astro";
import { formatDate, sortByDateDesc } from "astro-newspaper-theme/lib/format";
import { themeConfig } from "@/theme.config";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"articles">;
}

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter((heading) => heading.depth === 2);
const articles = sortByDateDesc(await getCollection("articles"));
const currentIndex = articles.findIndex((article) => article.id === entry.id);
const newerArticle = currentIndex > 0 ? articles[currentIndex - 1] : null;
const olderArticle =
  currentIndex >= 0 && currentIndex < articles.length - 1
    ? articles[currentIndex + 1]
    : null;
const previousArticle = newerArticle
  ? {
      href: `/articles/${newerArticle.id}/`,
      title: newerArticle.data.title,
      date: newerArticle.data.date,
    }
  : null;
const nextArticle = olderArticle
  ? {
      href: `/articles/${olderArticle.id}/`,
      title: olderArticle.data.title,
      date: olderArticle.data.date,
    }
  : null;
---

<BaseLayout title={entry.data.title} description={entry.data.description} config={themeConfig}>
  <Masthead config={themeConfig} />
  <main class="detail-page">
    <article class="column-page">
      <header class="column-page__header column-page__header--article">
        <StampTag label={entry.data.category} tone="blue" />
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date, themeConfig)}</time>
        {
          entry.data.tags.length > 0 && (
            <div class="article-index-terms" aria-label="文章索引词">
              <span class="article-index-terms__label">索引词</span>
              <span class="article-index-terms__list">{entry.data.tags.join(" / ")}</span>
            </div>
          )
        }
      </header>
      <ArticleToc headings={tocHeadings} numberStyle={themeConfig.tocNumberStyle} />
      <div class="article-progress" data-article-progress aria-hidden="true">
        <span></span>
      </div>
      <div class="prose" data-article-body>
        <Content />
      </div>
      {
        articles.length > 1 && (
          <ArticleReadMore
            indexHref="/articles/"
            indexLabel="返回专栏"
            previous={previousArticle}
            next={nextArticle}
            config={themeConfig}
          />
        )
      }
    </article>
  </main>
</BaseLayout>

<script>
  const progressRoot = document.querySelector<HTMLElement>("[data-article-progress]");
  const articleBody = document.querySelector<HTMLElement>("[data-article-body]");

  if (progressRoot && articleBody) {
    let ticking = false;

    const updateProgress = () => {
      const start = articleBody.offsetTop - window.innerHeight * 0.72;
      const end = articleBody.offsetTop + articleBody.offsetHeight - window.innerHeight;
      const range = Math.max(1, end - start);
      const current = window.scrollY - start;
      const progress = Math.min(1, Math.max(0, current / range));

      progressRoot.style.setProperty("--article-progress", String(progress));
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(updateProgress);
      }
    };

    updateProgress();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    window.addEventListener("load", requestUpdate, { once: true });
  }
</script>
