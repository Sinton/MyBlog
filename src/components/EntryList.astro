---
import { formatDate } from "../lib/format";
import type { NewspaperThemeConfig } from "../lib/theme-config";

interface EntryItem {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    category?: string;
  };
}

interface Props {
  entries: EntryItem[];
  basePath: string;
  label: string;
  config?: NewspaperThemeConfig;
}

const { entries, basePath, label, config } = Astro.props;

---

<section class="entry-list" aria-label={label}>
  <div class="section-kicker">{label}</div>
  {
    entries.map((entry) => (
      <article class="entry-list__item">
        <a href={`${basePath}/${entry.id}/`}>
          <span class="entry-list__date">{formatDate(entry.data.date, config)}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.description}</p>
          <span class="entry-list__meta">
            {entry.data.category ?? ""}
          </span>
        </a>
      </article>
    ))
  }
</section>
