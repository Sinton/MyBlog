---
import {
  defaultThemeConfig,
  type MastheadGlyph,
  type NewspaperThemeConfig,
} from "../lib/theme-config";

interface Props {
  config?: NewspaperThemeConfig;
  /** 传入内容的发布/更新日期（文章、文档详情页使用）。
   * 不传时报头日期将在客户端水合为读者的本地当天时间。 */
  date?: Date;
}

const { config = defaultThemeConfig, date } = Astro.props;
const isStaticDate = date !== undefined;

const displayDate = date ?? new Date();

const issueDate = new Intl.DateTimeFormat(config.lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: config.timezone,
}).format(displayDate);

const issueWeekday = new Intl.DateTimeFormat(config.lang, {
  weekday: "long",
  timeZone: config.timezone,
}).format(displayDate);

const githubLink =
  config.socialLinks.find((link) => link.label.toLowerCase() === "github") ??
  config.socialLinks[0];
const xLink =
  config.socialLinks.find((link) => ["x", "twitter"].includes(link.label.toLowerCase())) ??
  config.socialLinks[1];
const glyphs: MastheadGlyph[] =
  config.mastheadGlyphs?.length
    ? config.mastheadGlyphs
    : Array.from(config.siteTitle).map((text) => ({ text }));
const glyphCount = Math.max(glyphs.length, 1);
const mastheadTitleStyle =
  glyphCount === 4
    ? undefined
    : [
        `--masthead-glyph-count: ${glyphCount}`,
        `--masthead-title-size: clamp(${Math.min(5, 20 / glyphCount)}rem, ${45.6 / glyphCount}vw, 10.5rem)`,
        `--masthead-mobile-title-size: clamp(2.45rem, ${56 / glyphCount}vw, 5.2rem)`,
      ].join("; ");
---

<header class="masthead">
  <div class="masthead__topline">
    <span>{config.issue}</span>
    <span>{config.siteSubtitle}</span>
    <div class="masthead__social" aria-label="社交链接">
      {
        githubLink && (
          <a href={githubLink.href} aria-label={githubLink.label} title={githubLink.label}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 2.4c-5.4 0-9.8 4.4-9.8 9.8 0 4.3 2.8 8 6.7 9.3.5.1.7-.2.7-.5v-1.8c-2.7.6-3.3-1.1-3.3-1.1-.4-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.8.8.1-.6.3-1.1.6-1.4-2.2-.2-4.5-1.1-4.5-4.8 0-1.1.4-1.9 1-2.6-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1 .8-.2 1.6-.3 2.5-.3s1.7.1 2.5.3c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.6.7 1 1.5 1 2.6 0 3.7-2.3 4.5-4.5 4.8.4.3.7 1 .7 2v3c0 .3.2.6.7.5 3.9-1.3 6.7-5 6.7-9.3 0-5.4-4.4-9.8-9.8-9.8Z"
              />
            </svg>
            <strong class="sr-only">{githubLink.label}</strong>
          </a>
        )
      }
      {
        xLink && (
          <a href={xLink.href} aria-label={xLink.label} title={xLink.label}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.8 3h3.1l-6.8 7.8L22 21h-6.2l-4.9-6.3L5.4 21H2.3l7.3-8.4L2 3h6.4l4.4 5.8L17.8 3Zm-1.1 16.2h1.7L7.5 4.7H5.7l11 14.5Z" />
            </svg>
            <strong class="sr-only">{xLink.label}</strong>
          </a>
        )
      }
    </div>
  </div>
  <div class="masthead__nameplate">
    <div class="masthead__sidebox">
      <span>创刊</span>
      <strong>{config.since}</strong>
      <span>{config.location}</span>
    </div>
    <a
      class:list={["masthead__title", glyphCount !== 4 && "masthead__title--dynamic"]}
      href="/"
      aria-label={`${config.siteTitle}首页`}
      style={mastheadTitleStyle}
    >
      {
        glyphs.map((glyph, index) => (
          <span
            class:list={[
              "masthead__glyph",
              `masthead__glyph--slot-${index + 1}`,
              index === glyphs.length - 1 && glyphs.length > 1 && "masthead__glyph--last",
              glyph.tone && glyph.tone !== "default" && `masthead__glyph--${glyph.tone}`,
            ]}>{glyph.text}</span>
        ))
      }
    </a>
    <div class="masthead__sidebox">
      <span>版次</span>
      <strong>{config.frequency}</strong>
      <span
        class="masthead__date"
        data-static-date={isStaticDate ? "true" : "false"}
        data-lang={config.lang}
        data-timezone={config.timezone}
      >
        <span class="js-masthead-date">{issueDate}</span>
        <span class="js-masthead-weekday">{issueWeekday}</span>
      </span>
    </div>

<script>
  const container = document.querySelector<HTMLElement>(
    '.masthead__date[data-static-date="false"]',
  );

  if (container) {
    const dateEl  = container.querySelector(".js-masthead-date");
    const weekEl  = container.querySelector(".js-masthead-weekday");
    const lang     = container.dataset.lang     ?? "zh-CN";
    const timezone = container.dataset.timezone ?? "Asia/Shanghai";
    const now      = new Date();

    if (dateEl) {
      dateEl.textContent = new Intl.DateTimeFormat(lang, {
        year:     "numeric",
        month:    "long",
        day:      "numeric",
        timeZone: timezone,
      }).format(now);
    }

    if (weekEl) {
      weekEl.textContent = new Intl.DateTimeFormat(lang, {
        weekday:  "long",
        timeZone: timezone,
      }).format(now);
    }
  }
</script>
  </div>
  <nav class="masthead__nav" aria-label="Primary navigation">
    {
      config.navItems.map(({ label, href }) => (
        <a href={href} class="masthead__nav-item">
          <strong>{label}</strong>
        </a>
      ))
    }
  </nav>
</header>
