---
import "../styles/global.css";
import "lenis/dist/lenis.css";
import BackToTop from "../components/BackToTop.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import {
  defaultThemeConfig,
  type NewspaperThemeConfig,
} from "../lib/theme-config";
import mastheadFontWoBaoUrl from "@fontsource/zhi-mang-xing/files/zhi-mang-xing-118-400-normal.woff2?url";
import mastheadFontDeUrl from "@fontsource/zhi-mang-xing/files/zhi-mang-xing-119-400-normal.woff2?url";
import mastheadFontWanUrl from "@fontsource/zhi-mang-xing/files/zhi-mang-xing-114-400-normal.woff2?url";
import jetbrainsMonoUrl from "@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  config?: NewspaperThemeConfig;
}

const { config = defaultThemeConfig } = Astro.props;
const title = Astro.props.title ?? config.siteTitle;
const description = Astro.props.description ?? config.description;
const pageTitle =
  title === config.siteTitle ? title : `${title} | ${config.siteTitle}`;

const fontFaceCss = `
@font-face {
  font-family: "Newspaper Masthead Calligraphy";
  font-style: normal;
  font-display: block;
  font-weight: 400;
  src: url("${mastheadFontWoBaoUrl}") format("woff2");
  unicode-range: U+6211, U+62A5;
}

@font-face {
  font-family: "JetBrains Mono";
  font-style: normal;
  font-display: swap;
  font-weight: 400;
  src: url("${jetbrainsMonoUrl}") format("woff2");
}

@font-face {
  font-family: "Newspaper Masthead Calligraphy";
  font-style: normal;
  font-display: block;
  font-weight: 400;
  src: url("${mastheadFontDeUrl}") format("woff2");
  unicode-range: U+7684;
}

@font-face {
  font-family: "Newspaper Masthead Calligraphy";
  font-style: normal;
  font-display: block;
  font-weight: 400;
  src: url("${mastheadFontWanUrl}") format("woff2");
  unicode-range: U+665A;
}
`;
---

<!doctype html>
<html lang={config.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preload" href={mastheadFontWoBaoUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={mastheadFontDeUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={mastheadFontWanUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jetbrainsMonoUrl} as="font" type="font/woff2" crossorigin />
    <style is:inline set:html={fontFaceCss}></style>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="paper-shell">
      <slot />
    </div>
    <SmoothScroll />
    <BackToTop />
  </body>
</html>
