---
import "../styles/global.css";
import "@fontsource/zhi-mang-xing/index.css";
import BackToTop from "../components/BackToTop.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import {
  defaultThemeConfig,
  type NewspaperThemeConfig,
} from "../lib/theme-config";
import { getMastheadFontPreloads } from "../lib/masthead-font";
import jetbrainsMonoUrl from "@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  config?: NewspaperThemeConfig;
}

const { config = defaultThemeConfig } = Astro.props;
const title = Astro.props.title ?? config.siteTitle;
const description = Astro.props.description ?? config.description;
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;

const pageTitle =
  title === config.siteTitle ? title : `${title} | ${config.siteTitle}`;
const mastheadFontPreloads = getMastheadFontPreloads(config);

const fontFaceCss = `
@font-face {
  font-family: "JetBrains Mono";
  font-style: normal;
  font-display: swap;
  font-weight: 400;
  src: url("${jetbrainsMonoUrl}") format("woff2");
}
`;
---

<!doctype html>
<html lang={config.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content={config.siteTitle} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {
      mastheadFontPreloads.map((href) => (
        <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
      ))
    }
    <link rel="preload" href={jetbrainsMonoUrl} as="font" type="font/woff2" crossorigin />
    <style is:inline set:html={fontFaceCss}></style>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="paper-shell">
      <slot />
    </div>
    {config.enableSmoothScroll && <SmoothScroll />}
    <BackToTop label={config.backToTopLabel} />
  </body>
</html>
