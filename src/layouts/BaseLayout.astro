---
import "../styles/global.css";
import "lenis/dist/lenis.css";
import BackToTop from "../components/BackToTop.astro";
import {
  defaultThemeConfig,
  type NewspaperThemeConfig,
} from "../lib/theme-config";
import mastheadFontWoBaoUrl from "@fontsource/zhi-mang-xing/files/zhi-mang-xing-118-400-normal.woff2?url";
import mastheadFontDeUrl from "@fontsource/zhi-mang-xing/files/zhi-mang-xing-119-400-normal.woff2?url";
import mastheadFontWanUrl from "@fontsource/zhi-mang-xing/files/zhi-mang-xing-114-400-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  config?: NewspaperThemeConfig;
}

const { config = defaultThemeConfig } = Astro.props;
const title = Astro.props.title ?? config.siteTitle;
const description = Astro.props.description ?? config.description;
const pageTitle =
  title === config.siteTitle ? title : `${title} | ${config.siteTitle}`;
---

<!doctype html>
<html lang={config.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preload" href={mastheadFontWoBaoUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={mastheadFontDeUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={mastheadFontWanUrl} as="font" type="font/woff2" crossorigin />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="paper-shell">
      <slot />
    </div>
    <BackToTop />
  </body>
</html>
